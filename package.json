{
  "name": "@vinv/vinv-schema",
  "version": "0.0.1-alpha.0",
  "description": "vinv virtual forest inventory schema",
  "main": "./dist/schema.umd.js",
  "module": "./dist/schema.umd.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "node --experimental-json-modules ./build/build.js && npm run test",
    "test": "node --experimental-json-modules ./test/test.js",

    "documentation": "node --experimental-json-modules ./test/test.js && jsonschema2md -x - -d 0.1-alpha/dist -o docs/0.1-alpha/ -e schema.json",
    "dev": "rollup --config -w",
    "buildRollup": "rm -rf dist && rollup --config && tsc --emitDeclarationOnly",
    "build-0.1-alpha": "npm run build && npm run buildRollup && npm run documentation",

    "generate": "openapi --input ./tmp/openapi_json/0.1-alpha.json --output ./tmp/openapi/test3.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinv-group/vinv-schema.git"
  },
  "keywords": [
    "vinv",
    "virtual",
    "inventory",
    "schema",
    "forestry"
  ],
  "author": "Gerrit Balindt",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vinv-group/vinv-schema/issues"
  },
  "homepage": "https://github.com/vinv-group/vinv-schema#readme",
  "directories": {
    "test": "test"
  },
  "devDependencies": {
    "@adobe/jsonschema2md": "^4.0.0",
    "@apidevtools/json-schema-ref-parser": "^9.0.9",
    "@rollup/plugin-commonjs": "^19.0.1",
    "@rollup/plugin-typescript": "^8.2.3",
    "@walmartlabs/json-to-simple-graphql-schema": "^2.0.4",
    "ajv": "^8.6.2",
    "ajv-formats": "^2.1.0",
    "get-graphql-from-jsonschema": "^8.0.13",
    "graphql": "^15.5.1",
    "mocha": "^9.0.2",
    "openapi-to-graphql": "^2.5.1",
    "openapi-typescript": "^4.0.2",
    "openapi-typescript-codegen": "^0.9.3",
    "rollup": "^2.53.3",
    "typescript": "^4.3.5",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.0.2",
    "rollup-plugin-terser": "^7.0.2"
  },
  "type": "module"
}
