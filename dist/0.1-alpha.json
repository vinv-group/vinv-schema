{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/dist/0.1-alpha.json",
  "title": "vinv schema",
  "description": "Lightweight data standard for individual tree based forest management, visualisation & analytics",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "examples": [
        "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/vinv.json"
      ]
    },
    "v": {
      "title": "Version of the used vinv schema, the file should be validated against",
      "type": "string",
      "pattern": "^[0-9]\\.[0-9](-alpha|-beta|-stable)?$",
      "examples": [
        "0.1",
        "0.1-beta"
      ]
    },
    "trees": {
      "type": [
        "array",
        "null"
      ],
      "minItems": 1,
      "maxItems": 2,
      "items": [
        {
          "title": "Tree",
          "description": "Individual Tree Details",
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]*$"
          },
          "additionalProperties": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Tree definition",
            "description": "",
            "type": "array",
            "minItems": 5,
            "maxItems": 7,
            "items": [
              {
                "$schema": "http://json-schema.org/draft-07/schema#",
                "title": "Location",
                "description": "",
                "type": "array",
                "minItems": 1,
                "maxItems": 2,
                "items": [
                  {
                    "$schema": "http://json-schema.org/draft-07/schema#",
                    "title": "Coordinates",
                    "description": "Anchor point of the Object on a map. Array of longitude, latitude and [altitude] coordinate. Reference system: WGS84 Web Mercator with longitude and latitude units of decimal degrees.",
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 3,
                    "additionalItems": {
                      "type": "number",
                      "title": "[Altitude]",
                      "description": "The altitude of the position in meters above mean sea level. (2 decimal places max)",
                      "minimum": 0
                    },
                    "items": [
                      {
                        "title": "Longitude",
                        "description": "The decimal east–west position of a point. (7 decimal places max)",
                        "type": "number",
                        "minimum": -180,
                        "maximum": 180
                      },
                      {
                        "title": "Latitude",
                        "description": "The decimal north–south position of a point. (7 decimal places max)",
                        "type": "number",
                        "minimum": -90,
                        "maximum": 90
                      }
                    ]
                  },
                  {
                    "title": "Accuracy",
                    "description": "The decimal accuracy of coordinates in meter (2 decimal places max).",
                    "type": [
                      "number",
                      "null"
                    ],
                    "minimum": 0
                  }
                ]
              },
              {
                "$schema": "http://json-schema.org/draft-07/schema#",
                "title": "Tree species",
                "description": "Tree Species values taken from https://github.com/b-lack/tree-species",
                "type": "string",
                "pattern": "^[a-zA-Z0-9_-]{3}$",
                "examples": [
                  "JM2",
                  "sf6",
                  "9hD",
                  "u2-"
                ]
              },
              {
                "title": "Diameter at Breast Height",
                "description": "Diameter in centimeter",
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0.1,
                "maximum": 100
              },
              {
                "title": "Height",
                "description": "Height in meter",
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0.1,
                "maximum": 100
              },
              {
                "title": "Additional stem measurements",
                "type": [
                  "array",
                  "null"
                ],
                "uniqueItems": true,
                "minItems": 1,
                "items": {
                  "$schema": "http://json-schema.org/draft-07/schema#",
                  "title": "Diameter at height",
                  "description": "Array including height and diameter at height",
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "additionalItems": false,
                  "items": [
                    {
                      "type": "number",
                      "title": "Height",
                      "description": "Height of tree in PERCENT where diameter is measured",
                      "minimum": 0.1,
                      "maximum": 1,
                      "examples": [
                        0.5,
                        0.1
                      ]
                    },
                    {
                      "type": "number",
                      "title": "Diameter",
                      "description": "Diameter in CENTIMETER at measured height",
                      "minimum": 0.1,
                      "maximum": 100
                    }
                  ]
                }
              },
              {
                "title": "birth",
                "description": "Birthday of the tree",
                "examples": [
                  "2018-11-13"
                ],
                "type": [
                  "string",
                  "null"
                ],
                "format": "date"
              },
              {
                "type": [
                  "object",
                  "null"
                ],
                "title": "Visualization",
                "description": "absolute or relative path to file",
                "additionalProperties": false,
                "properties": {
                  "obj": {
                    "title": "3D graphics file",
                    "type": "string",
                    "format": "url"
                  },
                  "las": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "url"
                  },
                  "laz": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "url"
                  }
                }
              }
            ]
          }
        },
        {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Changes",
            "description": "Changes to the tree data",
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              {
                "title": "Tree Id",
                "description": "URL-friendly id",
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]*$",
                "maxLength": 36
              },
              {
                "title": "Change",
                "description": "Date and time when change happened.",
                "examples": [
                  "2018-11-13T20:20:39+00:00"
                ],
                "type": "string",
                "format": "date-time"
              },
              {
                "title": "Tree data change",
                "description": "Tree state before manipulation.",
                "$ref": "#/properties/trees/items/0/additionalProperties"
              }
            ]
          }
        }
      ]
    },
    "roads": {
      "type": [
        "array",
        "null"
      ],
      "minItems": 1,
      "maxItems": 2,
      "items": [
        {
          "title": "Road",
          "description": "Road Details",
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]*$"
          },
          "items": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Track definition",
            "description": "",
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": [
              {
                "type": "array",
                "title": "LineString coordinates",
                "additionalItems": {
                  "$ref": "#/properties/trees/items/0/additionalProperties/items/0"
                },
                "items": [
                  {
                    "$ref": "#/properties/trees/items/0/additionalProperties/items/0"
                  }
                ],
                "minItems": 2
              },
              {
                "title": "Width",
                "description": "Width of the track in METER",
                "type": "string"
              }
            ]
          }
        },
        {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Changes",
            "description": "Changes to the track data",
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              {
                "title": "Track Id",
                "description": "URL-friendly id",
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]*$",
                "maxLength": 36
              },
              {
                "title": "Change",
                "description": "Date and time when change happened.",
                "examples": [
                  "2018-11-13T20:20:39+00:00"
                ],
                "type": "string",
                "format": "date-time"
              },
              {
                "title": "Track data change",
                "description": "Tree state before manipulation.",
                "$ref": "#/properties/roads/items/0/items"
              }
            ]
          }
        }
      ]
    },
    "area": {
      "type": [
        "array",
        "null"
      ],
      "minItems": 1,
      "maxItems": 2,
      "items": [
        {
          "title": "Stand",
          "description": "Stand Details",
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]*$"
          },
          "additionalProperties": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Area definition",
            "description": "",
            "type": "array",
            "minItems": 1,
            "items": [
              {
                "type": "array",
                "title": "Polygon coordinates",
                "minItems": 1,
                "items": {
                  "type": "array",
                  "title": "Polygon coordinates",
                  "additionalItems": {
                    "$ref": "#/properties/trees/items/0/additionalProperties/items/0"
                  },
                  "items": [
                    {
                      "$ref": "#/properties/trees/items/0/additionalProperties/items/0"
                    }
                  ],
                  "minItems": 3
                }
              }
            ]
          }
        },
        {
          "type": [
            "array",
            "null"
          ],
          "additionalItems": false,
          "items": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Changes",
            "description": "Changes to the track data",
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": [
              {
                "title": "Track Id",
                "description": "URL-friendly id",
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]*$",
                "maxLength": 36
              },
              {
                "title": "Change",
                "description": "Date and time when change happened.",
                "examples": [
                  "2018-11-13T20:20:39+00:00"
                ],
                "type": "string",
                "format": "date-time"
              },
              {
                "title": "Track data change",
                "description": "Tree state before manipulation.",
                "$ref": "#/properties/area/items/0/additionalProperties"
              }
            ]
          }
        }
      ]
    },
    "fallbacks": {
      "title": "Trees inherit from fallback detail",
      "description": "Trees inherit from fallback detail",
      "type": "array",
      "additionalItems": false,
      "items": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Fallbacks",
        "description": "",
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": [
          {
            "title": "Filter",
            "description": "Define Trees to be replaced by Fallback tree data.",
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "array",
            "minItems": 2,
            "items": [
              {
                "title": "Tree Species",
                "description": "Array of tree species to be filtered.",
                "type": "array",
                "items": {
                  "$ref": "#/properties/trees/items/0/additionalProperties/items/1"
                }
              },
              {
                "title": "Diameter range",
                "description": "Define range of maximum set tree diameter.",
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true,
                "items": [
                  {
                    "title": "Minimum diameter",
                    "type": "number",
                    "minimum": 0
                  },
                  {
                    "title": "Maximum diameter",
                    "type": "number",
                    "maximum": 100
                  }
                ]
              },
              {
                "title": "Height range",
                "description": "Define Range of tree height to filter",
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true,
                "items": [
                  {
                    "title": "Minimum height",
                    "type": "number",
                    "minimum": 0.1
                  },
                  {
                    "title": "Maximum height",
                    "type": "number",
                    "maximum": 100
                  }
                ]
              },
              {
                "title": "Birthday range",
                "description": "Define Range of tree age to filter",
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true,
                "items": [
                  {
                    "title": "Minimum height",
                    "description": "Minimum date of the trees birthday.",
                    "examples": [
                      "2018-11-13"
                    ],
                    "type": "string",
                    "format": "date"
                  },
                  {
                    "title": "Maximum height",
                    "description": "Maximum date of the  trees birthday.",
                    "examples": [
                      "2018-11-13"
                    ],
                    "type": "string",
                    "format": "date"
                  }
                ]
              },
              {
                "title": "Location radius",
                "$ref": "#/properties/trees/items/0/additionalProperties/items/0/items/0",
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true,
                "items": [
                  {
                    "title": "Radius",
                    "description": "Radius in Meter.",
                    "examples": [
                      "56.42"
                    ],
                    "type": "number"
                  },
                  {
                    "title": "Maximum height",
                    "description": "Maximum date of the  trees birthday.",
                    "examples": [
                      "2018-11-13"
                    ],
                    "type": "string",
                    "format": "date"
                  }
                ]
              },
              {
                "title": "3D representation of tree",
                "type": "object",
                "description": "absolute or relative path to file",
                "properties": {
                  "obj": {
                    "title": "3D graphics file",
                    "type": "string",
                    "format": "url"
                  },
                  "las": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "url"
                  },
                  "laz": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "url"
                  }
                }
              }
            ],
            "additionalItems": false
          },
          {
            "title": "Fallback tree data",
            "description": "Fallback data if \"Trees\" data is missing",
            "$ref": "#/properties/trees/items/0/additionalProperties"
          }
        ]
      }
    }
  },
  "required": [
    "v"
  ]
}