{
    "openapi": "3.0.0",
    "info": {
        "title": "vinv",
        "description": "Lightweight open data exchange standard for individual tree based forest management, visualisation & analytics.",
        "contact": {
            "name": "API Support",
            "url": "http://www.vinv.io/support",
            "email": "support@vinv.io"
        },
        "license": {
            "name": "MIT",
            "url": "https://github.com/vinv-group/vinv-schema/blob/main/LICENSE"
        },
        "version": "0.1-alpha"
    },
    "externalDocs": {
        "description": "Find out more about vinv",
        "url": "https://vinv.io"
    },
    "servers": [
        {
            "url": "http://localhost:18512/",
            "description": "Localhost"
        },
        {
            "url": "https://api.vinv.io/v1",
            "description": "vinv"
        }
    ],
    "paths": {
        "/trees": {
            "get": {
                "tags": [
                    "Trees"
                ],
                "description": "Returns all trees",
                "responses": {
                    "200": {
                        "description": "A list of pets.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "vinv_jwt_auth": []
                    }
                ]
            }
        },
        "/tree": {
            "post": {
                "tags": [
                    "Tree"
                ],
                "description": "Creates new Tree",
                "operationId": "addTree",
                "responses": {
                    "200": {
                        "description": "Add Individual Tree.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "error payload",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorModel"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tree/{treeId}": {
            "get": {
                "description": "Returns tree based on ID",
                "summary": "Find tree by ID",
                "operationId": "getTreeById",
                "tags": [
                    "Tree"
                ],
                "parameters": [
                    {
                        "name": "treeId",
                        "in": "path",
                        "description": "ID of tree to use",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "style": "simple"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Individual Tree.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/tree"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "vinv_jwt_auth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "Authorize users by JWT token"
            }
        },
        "schemas": {
            "ErrorModel": {
                "type": "object",
                "required": [
                    "message",
                    "code"
                ],
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "integer",
                        "minimum": 100,
                        "maximum": 600
                    }
                }
            },
            "tree": {
                "title": "Tree",
                "description": "Tree definition",
                "type": "object",
                "required": [
                    "id",
                    "location",
                    "species",
                    "dbh"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    },
                    "location": {
                        "$ref": "#/components/schemas/location"
                    },
                    "species": {
                        "$ref": "#/components/schemas/species"
                    },
                    "dbh": {
                        "title": "Diameter at Breast Height",
                        "description": "Diameter in centimeter",
                        "type": "number",
                        "minimum": 1,
                        "maximum": 100,
                        "multipleOf": 1
                    },
                    "height": {
                        "title": "Height",
                        "description": "Height in centimeter",
                        "type": "number",
                        "minimum": 10,
                        "maximum": 1000,
                        "multipleOf": 1
                    },
                    "trunk": {
                        "title": "Trunk definition",
                        "description": "Diameter per height",
                        "type": "array",
                        "$ref": "#/components/schemas/dimensions_trunk"
                    },
                    "crown": {
                        "title": "Crown definition",
                        "description": "Diameter per height",
                        "type": "array",
                        "$ref": "#/components/schemas/dimensions_crown"
                    },
                    "birth": {
                        "title": "Birthday",
                        "description": "Birthday of the tree",
                        "type": "string",
                        "format": "date"
                    },
                    "image": {
                        "title": "Images",
                        "description": "List of absolute or relative path to file",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/image"
                        }
                    }
                }
            },
            "trees_history": {
                "title": "Tree Changes",
                "description": "Changes to the tree data",
                "type": "object",
                "required": [
                    "id",
                    "changeAt",
                    "definition"
                ],
                "properties": {
                    "id": {
                        "title": "Tree Id",
                        "description": "URL-friendly id",
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,36}$",
                        "maxLength": 36
                    },
                    "changedAt": {
                        "title": "Time of Change",
                        "description": "Date and time when change happened.",
                        "type": "string",
                        "format": "date-time"
                    },
                    "definition": {
                        "title": "Tree data change",
                        "description": "Tree state before manipulation.",
                        "$ref": "#/components/schemas/tree"
                    },
                    "uId": {
                        "title": "UserId",
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    }
                }
            },
            "new_area": {
                "title": "Area definition",
                "description": "",
                "type": "array",
                "minItems": 1,
                "items": {
                    "title": "Polygons",
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        
                        "title": "Polygon",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/location"
                        },
                        "minItems": 3
                    }
                }
            },
            "area_history": {
                "title": "Area Changes",
                "description": "Changes to the track data",
                "type": "object",
                "minItems": 3,
                "maxItems": 3,
                "properties": {
                    "id": {
                        "title": "Track Id",
                        "description": "URL-friendly id",
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]*$",
                        "maxLength": 36
                    },
                    "changedAt": {
                        "title": "Change",
                        "description": "Date and time when change happened.",
                        "type": "string",
                        "format": "date-time"
                    },
                    "definition": {
                        "title": "Area data change",
                        "description": "Tree state before manipulation.",
                        "$ref": "#/components/schemas/new_area"
                    },
                    "uId": {
                        "title": "UserId",
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    }
                }
            },
            "location": {
                "title": "Location",
                "description": "",
                "type": "object",
                "required": [
                    "coordinates"
                ],
                "properties": {
                    "coordinates": {
                        "$ref": "#/components/schemas/coordinates"
                    },
                    "accuracy": {
                        "title": "Accuracy",
                        "description": "The decimal accuracy of coordinates in meter (2 decimal places max).",
                        "type": "number",
                        "minimum": 0
                    }
                }
            },
            "coordinates": {
                "title": "Coordinates",
                "description": "Anchor point of the Object on a map. Array of longitude, latitude and [altitude] coordinate. Reference system: WGS84 Web Mercator with longitude and latitude units of decimal degrees.",
                "type": "array",
                "minItems": 2,
                "maxItems": 3,
                "items": {
                    "title": "Longitude",
                    "description": "The decimal east–west position of a point. (7 decimal places max)",
                    "type": "number"
                }
            },
            "species": {
                "title": "Tree species",
                "description": "Tree Species values taken from https://github.com/b-lack/tree-species",
                "type": "string",
                "pattern": "^[a-zA-Z0-9_-]{3}$"
            },
            "dimensions_trunk": {
                "title": "Additional trunk measurements",
                "type": "array",
                "uniqueItems": true,
                "minItems": 1,
                "items": {
                    "$ref": "#/components/schemas/diameter_height"
                }
            },
            "dimensions_crown": {
                "title": "Additional crown measurements",
                "type": "array",
                "uniqueItems": true,
                "minItems": 1,
                "items": {
                    "$ref": "#/components/schemas/diameter_height"
                }
            },
            "diameter_height": {
                "title": "Diameter at height",
                "description": "Array including height and diameter at height",
                "type": "object",
                "minItems": 2,
                "maxItems": 2,
                "properties": {
                    "height": {
                        "type": "number",
                        "title": "Height",
                        "description": "Height of tree in PERCENT where diameter is measured",
                        "minimum": 0.1,
                        "maximum": 1
                    },
                    "diameter": {
                        "type": "number",
                        "title": "Diameter",
                        "description": "Diameter in CENTIMETER at measured height",
                        "minimum": 0.1,
                        "maximum": 100
                    }
                }
            },
            "image": {
                "title": "Images",
                "description": "A universal resource identifier (URI), according to RFC3986.",
                "type": "string",
                "pattern": "uri"
            },
            "v": {
                "title": "Version",
                "description": "Version of the used vinv schema, the file should be validated against",
                "type": "string",
                "pattern": "^[0-9]\\.[0-9](-alpha|-beta|-stable)?$"
            },
            "id": {
                "title": "Document ID",
                "description": "Once created, this ID should never change.",
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{1,36}$"
            },
            "created": {
                "title": "Created",
                "description": "Date and time this document was created.",
                "type": "string",
                "format": "date-time"
            },
            "inventory": {
                "title": "Inventory",
                "description": "",
                "type": "object",
                "properties": {
                    "treeList": {
                        "title": "Trees",
                        "description": "List of individual tree definitions",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/tree"
                        }
                    },
                    "treeHistory": {
                        "title": "Tree changes",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/trees_history"
                        }
                    }
                },
                "required": [
                    "treeList"
                ]
            },
            "areas": {
                "title": "Areas",
                "description": "",
                "type": "object",
                "properties": {
                    "areaList": {
                        "title": "AreaList",
                        "description": "List of logical area definitions",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/new_area"
                        }
                    },
                    "areaHistory": {
                        "title": "Area changes",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/area_history"
                        }
                    }
                }
            },
            "extensions": {
                "title": "Extensions",
                "description": "List of functional extensions",
                "type": "object",
                "properties": {}
            }
        }
    }
}