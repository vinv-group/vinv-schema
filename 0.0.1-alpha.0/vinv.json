{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vinv",
  "description": "Lightweight data standard for individual tree based forest management, visualisation & analytics",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "tree": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tree definition",
      "description": "",
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": [
        {
          "$ref": "#/definitions/location"
        },
        {
          "$ref": "#/definitions/species"
        },
        {
          "title": "Diameter at Breast Height",
          "description": "Diameter in centimeter",
          "type": "number",
          "minimum": 1,
          "maximum": 100,
          "multipleOf": 1
        },
        {
          "title": "Height",
          "description": "Height in centimeter",
          "type": "number",
          "minimum": 10,
          "maximum": 1000,
          "multipleOf": 1
        },
        {
          "title": "Trunk definition",
          "description": "Diameter per height",
          "type": [
            "array",
            "null"
          ],
          "$ref": "#/definitions/dimensions_trunk"
        },
        {
          "title": "Crown definition",
          "description": "Diameter per height",
          "type": [
            "array",
            "null"
          ],
          "$ref": "#/definitions/dimensions_crown"
        },
        {
          "title": "Birthday",
          "description": "Birthday of the tree",
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        {
          "title": "Images",
          "description": "List of absolute or relative path to file",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/image"
          }
        }
      ]
    },
    "trees_history": {
      "title": "Tree Changes",
      "description": "Changes to the tree data",
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": [
        {
          "title": "Tree Id",
          "description": "URL-friendly id",
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,36}$",
          "maxLength": 36
        },
        {
          "title": "Time of Change",
          "description": "Date and time when change happened.",
          "examples": [
            "2018-11-13T20:20:39+00:00"
          ],
          "type": "string",
          "format": "date-time"
        },
        {
          "title": "Tree data change",
          "description": "Tree state before manipulation.",
          "$ref": "#/definitions/tree"
        }
      ]
    },
    "track": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Track definition",
      "description": "",
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "additionalItem": false,
      "items": [
        {
          "title": "LineString coordinates",
          "minItems": 2,
          "type": "array",
          "items": [
            {
              "$ref": "#/definitions/location"
            }
          ],
          "additionalItems": {
            "$ref": "#/definitions/location"
          }
        },
        {
          "title": "Width",
          "description": "Width of the track in METER",
          "type": "number",
          "minimum": 0.1,
          "maximum": 10
        }
      ]
    },
    "track_history": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Track Changes",
      "description": "Changes to the track data",
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": [
        {
          "title": "Track Id",
          "description": "URL-friendly id",
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]*$",
          "maxLength": 36
        },
        {
          "title": "Change",
          "description": "Date and time when change happened.",
          "examples": [
            "2018-11-13T20:20:39+00:00"
          ],
          "type": "string",
          "format": "date-time"
        },
        {
          "title": "Track data change",
          "description": "Tree state before manipulation.",
          "$ref": "#/definitions/track"
        }
      ]
    },
    "area": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Area definition",
      "description": "",
      "type": "array",
      "minItems": 1,
      "additionalItem": false,
      "items": {
        "type": "array",
        "title": "Polygon coordinates",
        "minItems": 1,
        "items": {
          "type": "array",
          "title": "Polygon coordinates",
          "items": {
            "$ref": "#/definitions/location"
          },
          "minItems": 3
        }
      }
    },
    "area_history": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Area Changes",
      "description": "Changes to the track data",
      "type": "object",
      "minItems": 3,
      "maxItems": 3,
      "properties": {
        "id": {
          "title": "Track Id",
          "description": "URL-friendly id",
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]*$",
          "maxLength": 36
        },
        "changedAt": {
          "title": "Change",
          "description": "Date and time when change happened.",
          "examples": [
            "2018-11-13T20:20:39+00:00"
          ],
          "type": "string",
          "format": "date-time"
        },
        "definition": {
          "title": "Track data change",
          "description": "Tree state before manipulation.",
          "$ref": "#/definitions/area"
        }
      }
    },
    "location": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Location",
      "description": "",
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "additionalItems": false,
      "items": [
        {
          "$ref": "#/definitions/coordinates"
        },
        {
          "title": "Accuracy",
          "description": "The decimal accuracy of coordinates in meter (2 decimal places max).",
          "type": "number",
          "minimum": 0
        }
      ]
    },
    "coordinates": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Coordinates",
      "description": "Anchor point of the Object on a map. Array of longitude, latitude and [altitude] coordinate. Reference system: WGS84 Web Mercator with longitude and latitude units of decimal degrees.",
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "additionalItems": false,
      "items": {
        "title": "Longitude",
        "description": "The decimal east–west position of a point. (7 decimal places max)",
        "type": "number"
      }
    },
    "dbh": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Diameter at breast height",
      "description": "Array including height and diameter",
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        {
          "type": "number",
          "title": "Height",
          "description": "Height in meter of diameter measurment",
          "const": 1.3,
          "default": 1.3
        },
        {
          "type": "number",
          "title": "Diameter",
          "description": "Diameter in centimeter as measured height",
          "minimum": 0,
          "maximum": 100
        }
      ]
    },
    "species": {
      "title": "Tree species",
      "description": "Tree Species values taken from https://github.com/b-lack/tree-species",
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{3}$"
    },
    "dimensions_trunk": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Additional trunk measurements",
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/diameter_height"
      }
    },
    "dimensions_crown": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Additional crown measurements",
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/diameter_height"
      }
    },
    "diameter_height": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Diameter at height",
      "description": "Array including height and diameter at height",
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "additionalItems": false,
      "properties": {
        "height": {
          "type": "number",
          "title": "Height",
          "description": "Height of tree in PERCENT where diameter is measured",
          "minimum": 0.1,
          "maximum": 1,
          "examples": [
            0.5,
            0.1
          ]
        },
        "diameter": {
          "type": "number",
          "title": "Diameter",
          "description": "Diameter in CENTIMETER at measured height",
          "minimum": 0.1,
          "maximum": 100
        }
      }
    },
    "filter": {
      "title": "Filter definition",
      "type": "array",
      "items": [
        {
          "title": "Location radius",
          "type": [
            "array",
            "null"
          ],
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": [
            {
              "$ref": "#/definitions/coordinates"
            },
            {
              "title": "Radius",
              "description": "Radius in Meter.",
              "examples": [
                "56.42"
              ],
              "type": "number"
            }
          ]
        },
        {
          "title": "Tree Species",
          "description": "Array of tree species to be filtered.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/species"
          }
        },
        {
          "title": "DBH range",
          "description": "Define range of maximum set tree diameter.",
          "type": [
            "array",
            "null"
          ],
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "title": "Minimum diameter",
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            {
              "title": "Maximum diameter",
              "type": [
                "number",
                "null"
              ],
              "maximum": 100
            }
          ]
        },
        {
          "title": "Height range",
          "description": "Define Range of tree height to filter",
          "type": [
            "array",
            "null"
          ],
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "title": "Minimum height",
              "type": [
                "number",
                "null"
              ],
              "minimum": 1,
              "multipleOf": 1
            },
            {
              "title": "Maximum height",
              "type": [
                "number",
                "null"
              ],
              "maximum": 1000,
              "multipleOf": 1
            }
          ]
        },
        {
          "title": "Birthday range",
          "description": "Define Range of tree age to filter",
          "type": [
            "array",
            "null"
          ],
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "title": "Minimum height",
              "description": "Minimum date of the trees birthday.",
              "examples": [
                "2018-11-13"
              ],
              "type": "string",
              "format": "date"
            },
            {
              "title": "Maximum height",
              "description": "Maximum date of the  trees birthday.",
              "examples": [
                "2018-11-13"
              ],
              "type": "string",
              "format": "date"
            }
          ]
        }
      ],
      "additionalItems": false
    },
    "image": {
      "title": "Images",
      "description": "A universal resource identifier (URI), according to RFC3986.",
      "type": "string",
      "format": "uri"
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "examples": [
        "https://schema.vinv.io/0.0.1-alpha.0/vinv.min.json"
      ]
    },
    "v": {
      "title": "Version",
      "description": "Version of the used vinv schema, the file should be validated against",
      "type": "string",
      "pattern": "^[0-9]\\.[0-9]\\.[0-9](-alpha\\.[0-9]|-beta\\.[0-9])?$",
      "examples": [
        "0.0.1",
        "0.0.1-beta.0"
      ]
    },
    "id": {
      "title": "Document ID",
      "description": "Once created, this ID should never change.",
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,36}$"
    },
    "created": {
      "title": "Created",
      "description": "Date and time this document was created.",
      "examples": [
        "2018-11-13T20:20:39+00:00"
      ],
      "type": "string",
      "format": "date-time"
    },
    "inventory": {
      "title": "Inventory",
      "type": "object",
      "properties": {
        "tree_status": {
          "title": "Tree List",
          "description": "Individual Tree Details",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/tree"
          },
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]{1,36}$"
          }
        },
        "tree_history": {
          "title": "Tree Changes List",
          "type": "array",
          "items": {
            "$ref": "#/definitions/trees_history"
          }
        }
      }
    },
    "areas": {
      "title": "Areas",
      "type": "object",
      "properties": {
        "area_status": {
          "title": "Area List",
          "description": "Area Details",
          "type": "array",
          "items": {
            "$ref": "#/definitions/area"
          }
        },
        "area_history": {
          "title": "Area Changes List",
          "type": "array",
          "items": {
            "$ref": "#/definitions/area_history"
          }
        }
      }
    },
    "extensions": {
      "title": "Extensions",
      "description": "List of functional extensions",
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]{1,36}$"
      },
      "properties": {}
    }
  },
  "required": [
    "v",
    "id",
    "created"
  ],
  "$id": "https://schema.vinv.io/0.0.1-alpha.0/vinv.json"
}