{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vinv",
  "description": "Lightweight data standard for individual tree based forest management, visualisation & analytics",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "tree": {
      "$ref": "./subschema-object/tree.json"
    },
    "trees_history": {
      "$ref": "./subschema-object/tree_history.json"
    },
    "track": {
      "$ref": "./subschema-object/track.json"
    },
    "track_history": {
      "$ref": "./subschema-object/track_history.json"
    },
    "area": {
      "$ref": "./subschema-object/area.json"
    },
    "area_history": {
      "$ref": "./subschema-object/area_history.json"
    },
    "location": {
      "$ref": "./subschema-object/location.json"
    },
    "coordinates": {
      "$ref": "./subschema-object/coordinates.json"
    },
    "dbh": {
      "$ref": "./subschema-object/dbh.json"
    },
    "species": {
      "$ref": "./subschema-object/species.json"
    },
    "dimensions_trunk": {
      "$ref": "./subschema-object/dimensions_trunk.json"
    },
    "dimensions_crown": {
      "$ref": "./subschema-object/dimensions_crown.json"
    },
    "diameter_height": {
      "$ref": "./subschema-object/diameter_height.json"
    },
    "filter": {
      "$ref": "./subschema-object/filter.json"
    },
    "image": {
      "$ref": "./subschema-object/image.json"
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "examples": [
        "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/vinv.json"
      ]
    },
    "v": {
      "title": "Version",
      "description": "Version of the used vinv schema, the file should be validated against",
      "type": "string",
      "pattern": "^[0-9]\\.[0-9]\\.[0-9](-alpha\\.[0-9]|-beta\\.[0-9])?$",
      "examples": [
        "0.0.1",
        "0.0.1-beta.0"
      ]
    },
    "id": {
      "title": "Document ID",
      "description": "Once created, this ID should never change.",
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,36}$"
    },
    "created": {
      "title": "Created",
      "description": "Date and time this document was created.",
      "examples": [
        "2018-11-13T20:20:39+00:00"
      ],
      "type": "string",
      "format": "date-time"
    },
    "inventory": {
      "title": "Inventory",
      "type": "object",
      "properties": {
        "tree_status": {
          "title": "Tree List",
          "description": "Individual Tree Details",
          "type": "array",
          "items": {
            "$ref": "#/definitions/tree"
          }
        },
        "tree_history": {
          "title": "Tree Changes List",
          "type": "array",
          "items": {
            "$ref": "#/definitions/trees_history"
          }
        }
      }
    },
    "areas": {
      "title": "Areas",
      "type": "object",
      "properties": {
        "area_status": {
          "title": "Area List",
          "description": "Area Details",
          "type": "array",
          "items": {
            "$ref": "#/definitions/area"
          }
        },
        "area_history": {
          "title": "Area Changes List",
          "type": "array",
          "items": {
            "$ref": "#/definitions/area_history"
          }
        }
      }
    },
    "extensions": {
      "title": "Extensions",
      "description": "List of functional extensions",
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]{1,36}$"
      },
      "properties": {}
    }
  },
  "required": [
    "v",
    "id",
    "created"
  ]
}