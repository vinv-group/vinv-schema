{
    "title": "Tree",
    "description": "Tree definition",
    "type": "object",
    "required": [
        "location",
        "species",
        "dbh"
    ],
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{1,36}$"
        },
        "location": {
            "$ref": "./location.json"
        },
        "species": {
            "$ref": "./species.json"
        },
        "dbh": {
            "title": "Diameter at Breast Height",
            "description": "Diameter in centimeter",
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "multipleOf" : 1
        },
        "height":{
            "title": "Height",
            "description": "Height in centimeter",
            "type": "number",
            "minimum": 10,
            "maximum": 1000,
            "multipleOf" : 1
        },
        "trunk": {
            "title": "Trunk definition",
            "description": "Diameter per height",
            "type": "array",
            "$ref": "./dimensions_trunk.json"
        },
        "crown": {
            "title": "Crown definition",
            "description": "Diameter per height",
            "type":  "array",
            "$ref": "./dimensions_crown.json"
        },
        "birth": {
            "title": "Birthday",
            "description": "Birthday of the tree",
            "type": "string",
            "format": "date"
        },
        "image": {
            "title": "Images",
            "description": "List of absolute or relative path to file",
            "type": "array",
            "items": {
                "$ref": "./image.json"
            }
        }
    }
}