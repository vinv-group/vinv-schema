{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/definitions/changes/area_history.json",
    "title": "Area Changes",
    "description": "Changes to the track data",
    "type": "array",
    "minItems": 3,
    "maxItems": 3,
    "items": [
        {
            "title": "Track Id",
            "description": "URL-friendly id",
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]*$",
            "maxLength": 36
        },
        {
            "title": "Change",
            "description": "Date and time when change happened.",
            "examples": ["2018-11-13T20:20:39+00:00"],
            "type": "string",
            "format": "date-time"
        },
        {
            "title": "Track data change",
            "description": "Tree state before manipulation.",
            "$ref": "../area.json"
        }
    ]
}