{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/alpha/0.1-alpha/definitions/changes.json",
    "title": "Changes",
    "description": "Changes to the tree data",
    "type": "array",
    "minItems": 3,
    "maxItems": 3,
    "items": [
        {
            "title": "Tree Id",
            "description": "URL-friendly id",
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]*$",
            "maxLength": 36
        },
        {
            "title": "Change",
            "description": "Date and time when change happened.",
            "examples": ["2018-11-13T20:20:39+00:00"],
            "type": "string",
            "format": "date-time"
        },
        {
            "title": "Tree data change",
            "description": "Tree state before manipulation.",
            "$ref": "../tree.json"
        }
    ]
}