{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/0.1-alpha/trees.json",
    "title": "Trees definition",
    "description": "",
    "type": "array",
    "additionalItems": false,
    "minItems": 5,
    "items": [
        {
            "$ref": "./coordinates.json"
        },
        {
            "$ref": "./species.json"
        },
        {
            "title": "Measured data",
            "type": "array",
            "minItems": 1,
            "additionalItems": {"$ref": "./diameter_height.json"},
            "uniqueItems": true,
            "items": [
                {"$ref": "./dbh.json"},
                {"$ref": "./height.json"}
            ]
        },
        {
            "title": "birth",
            "description": "Birthday of the tree",
            "examples": ["2018-11-13"],
            "type": ["string", "null"],
            "format": "date"
        },
        {
            "type": ["object", "null"],
            "description": "absolute or relative path to file",
            "properties": {
                "obj": {
                    "title": "3D graphics file",
                    "type": "string",
                    "format": "iri-reference"
                },
                "las": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "iri-reference"
                },
                "laz": {
                    "title": "Point Cloud File",
                    "type": "string",
                    "format": "iri-reference"
                }
            }
        }
    ]
}