{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/definitions/dbh.json",
    "title": "Diameter at breast height",
    "description": "Array including height and diameter",
    "type": "array",
    "minItems":2,
    "maxItems": 2,
    "items": [
        {
            "type": "number",
            "title": "Height",
            "description": "Height in meter of diameter measurment",
            "const": 1.3,
            "default": 1.3
        },
        {
            "type": "number",
            "title": "Diameter",
            "description": "Diameter in centimeter as measured height",
            "minimum": 0,
            "maximum": 100
        }
    ]
}