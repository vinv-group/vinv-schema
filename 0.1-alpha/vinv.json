{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/documentation/0.1-alpha/vinv.json",
    "title": "vinv",
    "description": "Lightweight data standard for individual tree based forest management, visualisation & analytics",
    "type": "object",
    "additionalProperties": false,
    "definitions": {
        "tree": {
            "$ref": "./subschema/tree.json"
        },
        "trees_history": {
            "$ref": "./subschema/tree_history.json"
        },
        "track": {
            "$ref": "./subschema/track.json"
        },
        "track_history": {
            "$ref": "./subschema/track_history.json"
        },
        "area": {
            "$ref": "subschema/area.json"
        },
        "area_history": {
            "$ref": "./subschema/area_history.json"
        },
        "location": {
            "$ref": "./subschema/location.json"
        },
        "coordinates": {
            "$ref": "./subschema/coordinates.json"
        },
        "dbh": {
            "$ref": "./subschema/dbh.json"
        },
        "species": {
            "$ref": "./subschema/species.json"
        },
        "dimensions_trunk": {
            "$ref": "./subschema/dimensions_trunk.json"
        },
        "dimensions_crown": {
            "$ref": "./subschema/dimensions_crown.json"
        },
        "diameter_height": {
            "$ref": "./subschema/diameter_height.json"
        },
        "filter": {
            "$ref": "./subschema/filter.json"
        },
        "image": {
            "$ref": "./subschema/image.json"
        }
    },
    "properties": {
        "$schema": {
            "type": "string",
            "examples": [
                "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/vinv.json"
            ]
        },
        "v": {
            "title": "Version",
            "description": "Version of the used vinv schema, the file should be validated against",
            "type": "string",
            "pattern": "^[0-9]\\.[0-9](-alpha|-beta|-stable)?$",
            "examples": [
                "0.1",
                "0.1-beta"
            ]
        },
        "id": {
            "title": "Document ID",
            "description": "Once created, this ID should never change.",
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{1,36}$",
            "examples": [
                "0.1",
                "0.1-beta"
            ]
        },
        "created": {
            "title": "Created",
            "description": "Date and time this document was created.",
            "examples": ["2018-11-13T20:20:39+00:00"],
            "type": "string",
            "format": "date-time"
        },
        "trees": {
            "title": "",
            "type": [
                "array",
                "null"
            ],
            "minItems": 1,
            "maxItems": 2,
            "items": [
                {
                    "title": "Tree",
                    "description": "Individual Tree Details",
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    },
                    "additionalProperties": {
                        "$ref": "#/definitions/tree"
                    }
                },
                {
                    "title": "Tree Changes",
                    "type": [
                        "array",
                        "null"
                    ],
                    "items": {
                        "$ref": "#/definitions/trees_history"
                    }
                }
            ]
        },
        "tracks": {
            "type": [
                "array",
                "null"
            ],
            "minItems": 1,
            "maxItems": 2,
            "items": [
                {
                    "title": "Track",
                    "description": "Track Details",
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    },
                    "additionalProperties": {
                        "$ref": "#/definitions/track"
                    }
                },
                {
                    "type": [
                        "array",
                        "null"
                    ],
                    "items": {
                        "$ref": "#/definitions/track_history"
                    }
                }
            ]
        },
        "areas":{
            "type": ["array", "null"],
            "minItems":1,
            "maxItems": 2,
            "items": [
                {
                    "title": "Area",
                    "description": "Area Details",
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[A-Za-z0-9_-]{1,36}$"
                    },
                    "additionalProperties": {"$ref": "#/definitions/area"}
                },
                {
                    "type":["array", "null"],
                    "items": {"$ref": "#/definitions/area_history"}
                }
            ]
        },
        "filters":{
            "type": ["array", "null"],
            "minItems":1,
            "maxItems": 2,
            "items": {"$ref": "#/definitions/filter"}
        },
        "extensions":{
            "title": "Extensions",
            "description": "List of functional extensions",
            "type": "object",
            "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]{1,36}$"
            },
            "properties": {}
        }
    },
    "required": [
        "v",
        "id",
        "created"
    ]
}