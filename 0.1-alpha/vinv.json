{
    "$schema": "http://json-schema.org/draft-06/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/alpha/0.1-alpha/vinv.json",
    "title": "vinv schema",
    "description": "Lightweight data standard for single-tree based forest management, visualisation & analytics",
    "type": "object",
    "additionalProperties": false,
    "properties":{
        "$schema": {
            "type": "string",
            "examples": [
                "https://raw.githubusercontent.com/vinv-group/vinv-schema/alpha/0.1-alpha/vinv.json"
            ]
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]\\.[0-9](\\-alpha|\\-beta)?$",
            "examples": [
                "0.1-beta"
            ]
        },
        "trees": {
            "type": "array",
            "minItems":1,
            "items": {
                "$ref": "./definitions/trees.json"
            }
        },
        "fallbacks":{
            "type":"array",
            "additionalProperties": false,
            "items": {"$ref": "./definitions/fallbacks.json"}
        },
        "processes":{
            "type":"array",
            "additionalProperties": false,
            "items": {"$ref": "./definitions/processes.json"}
        }
    },
    "required": [
        "version",
        "trees"
    ]
}