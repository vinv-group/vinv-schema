{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/vinv-group/vinv-schema/documentation/0.1-alpha/vinv.json",
    "title": "vinv",
    "description": "Lightweight data standard for individual tree based forest management, visualisation & analytics",
    "type": "object",
    "additionalProperties": false,
    "definitions": {
        "tree": {
            "$ref": "./subschema/tree.json"
        },
        "trees_history": {
            "$ref": "./subschema/tree_history.json"
        },
        "area": {
            "$ref": "subschema/area.json"
        },
        "area_history": {
            "$ref": "./subschema/area_history.json"
        },
        "location": {
            "$ref": "./subschema/location.json"
        },
        "coordinates": {
            "$ref": "./subschema/coordinates.json"
        },
        "species": {
            "$ref": "./subschema/species.json"
        },
        "dimensions_trunk": {
            "$ref": "./subschema/dimensions_trunk.json"
        },
        "dimensions_crown": {
            "$ref": "./subschema/dimensions_crown.json"
        },
        "diameter_height": {
            "$ref": "./subschema/diameter_height.json"
        },
        "image": {
            "$ref": "./subschema/image.json"
        }
    },
    "properties": {
        "$schema": {
            "type": "string",
            "examples": [
                "https://raw.githubusercontent.com/vinv-group/vinv-schema/main/0.1-alpha/vinv.json"
            ]
        },
        "v": {
            "title": "Version",
            "description": "Version of the used vinv schema, the file should be validated against",
            "type": "string",
            "pattern": "^[0-9]\\.[0-9](-alpha|-beta|-stable)?$",
            "examples": [
                "0.1",
                "0.1-beta"
            ]
        },
        "id": {
            "title": "Document ID",
            "description": "Once created, this ID should never change.",
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{1,36}$",
            "examples": [
                "0.1",
                "0.1-beta"
            ]
        },
        "created": {
            "title": "Created",
            "description": "Date and time this document was created.",
            "examples": ["2018-11-13T20:20:39+00:00"],
            "type": "string",
            "format": "date-time"
        },
        "inventory": {
            "title": "Inventory",
            "description": "",
            "type": "object",
            "properties": {
                "treeList":{
                    "title": "Trees",
                    "description": "List of individual tree definitions",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/tree"
                    }
                },
                "treeHistory": {
                    "title": "Tree changes",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/trees_history"
                    }
                }
            },
            "required": [
                "treeList"
            ]
        },
        
        "extensions":{
            "title": "Extensions",
            "description": "List of functional extensions",
            "type": "object",
            "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]{1,36}$"
            },
            "properties": {}
        }
    },
    "required": [
        "v",
        "id",
        "created"
    ]
}