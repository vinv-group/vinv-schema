{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Tree definition",
    "description": "",
    "type": "array",
    "minItems": 4,
    "maxItems": 8,
    "items": [
        {
            "$ref": "../vinv.json#/definitions/location"
        },
        {
            "$ref": "../vinv.json#/definitions/species"
        },
        {
            "title": "Diameter at Breast Height",
            "description": "Diameter in centimeter",
            "type": [
                "number",
                "null"
            ],
            "minimum": 1,
            "maximum": 100,
            "multipleOf" : 1
        },
        {
            "title": "Height",
            "description": "Height in centimeter",
            "type": [
                "number",
                "null"
            ],
            "minimum": 10,
            "maximum": 1000,
            "multipleOf" : 1
        },
        {
            "title": "Trunk definition",
            "description": "Diameter per height",
            "type": [
                "array",
                "null"
            ],
            "$ref": "../vinv.json#/definitions/dimensions_trunk"
        },
        {
            "title": "Crown definition",
            "description": "Diameter per height",
            "type": [
                "array",
                "null"
            ],
            "$ref": "../vinv.json#/definitions/dimensions_crown"
        },
        {
            "title": "birth",
            "description": "Birthday of the tree",
            "examples": [
                "2018-11-13"
            ],
            "type": [
                "string",
                "null"
            ],
            "format": "date"
        },
        {
            "title": "Images",
            "description": "List of absolute or relative path to file",
            "type": [
                "array",
                "null"
            ],
            "items": {
                "$ref": "../vinv.json#/definitions/image"
            }
        }
    ]
}